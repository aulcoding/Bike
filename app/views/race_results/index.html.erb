<!-- app/views/race_results/index.html.erb -->
<h1 style="text-align: center; font-size: 36px; font-weight: bold; color: #2c3e50;">Race Results</h1>

<table style="width: 100%; border-collapse: collapse; margin: 20px 0; font-family: 'Arial', sans-serif; color: #34495e;">
  <thead style="background-color: #3498db; color: white; text-align: left;">
    <tr>
      <th style="padding: 10px 15px; text-align: center;">Position</th>
      <th style="padding: 10px 15px;">Name</th>
      <th style="padding: 10px 15px;">Start Time</th>
      <th style="padding: 10px 15px;">Finish Time</th>
      <th style="padding: 10px 15px;">Behind Time</th>
    </tr>
  </thead>
  <tbody>
    <% @results.each_with_index do |result, index| %>
      <tr style="background-color: <%= index.even? ? '#ecf0f1' : '#f4f6f7' %>; text-align: center;">
        <td style="padding: 10px 15px; font-weight: bold; 
          <%= 'background-color: #e74c3c; color: white;' if result.position == 1 %>
          <%= 'background-color: #f39c12; color: white;' if result.position == 2 %>
          <%= 'background-color: #27ae60; color: white;' if result.position == 3 %>">
          <%= result.position %>
        </td>
        <td style="padding: 10px 15px;"><%= result.name %></td>
        <td style="padding: 10px 15px;"><%= result.start_time.strftime('%H:%M:%S') %></td>
        <td style="padding: 10px 15px;"><%= result.finish_time.strftime('%H:%M:%S') %></td>
        <td style="padding: 10px 15px;"><%= result.behind_time %></td>
      </tr>
    <% end %>
  </tbody>
</table>
